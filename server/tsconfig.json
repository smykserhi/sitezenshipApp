{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "baseUrl": "..",
    "paths": {
      "@shared/*": ["types/*"]
    }
  },
  "include": ["../server/**/*", "../data/**/*", "../types/**/*"]
}
